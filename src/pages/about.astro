---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About';
const description = 'Laurent Beaumois — founder of MeetLoyd, board-level agentic AI advisor to SI & IT services firms, and UN ITU SG17 Agentic AI Security Expert.';
---

<BaseLayout title={title} description={description}>
  <article class="py-12 bg-white dark:bg-slate-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <!-- Header with Photo -->
      <div class="flex flex-col md:flex-row gap-8 items-start mb-12">
        <div class="flex-shrink-0">
          <img
            src="/images/laurent-beaumois.jpg"
            alt="Laurent Beaumois - Founder of MeetLoyd and Agentic AI Advisor"
            class="w-48 h-48 md:w-64 md:h-64 rounded-lg object-cover shadow-xl"
            loading="eager"
          />
        </div>
        <div class="flex-1">
          <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">About Laurent Beaumois</h1>
          <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
            I'm all in on agentic AI. I founded <strong>MeetLoyd</strong>, the platform for the agentic era, and I advise the boards of system integrators and IT services firms on turning the agentic shift into revenue, governance, and a durable competitive edge.
          </p>
        </div>
      </div>

      <div class="prose prose-lg dark:prose-invert max-w-none">

        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mt-12 mb-4">What I do today</h2>

        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mt-6 mb-3">Founder, MeetLoyd</h3>
        <p>MeetLoyd is the enterprise platform for composing, governing, and operating teams of AI agents at scale — manifest-driven, MCP-native, and governed from day one. It is built for regulated, high-trust buyers and the SI/IT services firms who serve them.</p>

        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mt-6 mb-3">Board advisor to SI &amp; IT services firms</h3>
        <p>System integrators and IT services companies are at the center of the agentic transition — for their own operations and for their clients. I work at board level on agentic strategy, governance, and building a credible agentic offering.</p>

        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mt-6 mb-3">UN ITU SG17 — Agentic AI Security Expert</h3>
        <p>I contribute to international standards for agentic AI security and trustworthy digital identities through the United Nations' International Telecommunication Union (Study Group 17).</p>

        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mt-12 mb-4">Background</h2>
        <p>Twenty years across enterprise software, B2B SaaS, and financial services — as buyer, seller, and builder. Enterprise AI is not a research problem; it is an enterprise software problem: procurement, compliance, change management, integration, and trust. That experience is baked into how I build and advise.</p>
        <ul class="list-disc pl-6 space-y-2 text-slate-700 dark:text-slate-300">
          <li>Executive and leadership roles driving digital transformation and AI initiatives (incl. Wiiisdom, Boston MA)</li>
          <li>SAP Top Talent 2016; Winners' Circle / Global Quota Club recognition (2014, 2015)</li>
          <li>EMEA Key Contributor — led a license deal exceeding €3M (Q4 2015)</li>
          <li>Deep experience in B2B SaaS and Financial Services (FSI)</li>
        </ul>

        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mt-12 mb-4">Education &amp; Certifications</h2>
        <ul class="list-disc pl-6 space-y-2 text-slate-700 dark:text-slate-300">
          <li><strong>ESCP Business School</strong> (2006-2008)</li>
          <li><strong>Machine Learning Certification</strong> - Stanford University (2017)</li>
          <li><strong>AMF Professional Certification</strong> - Financial markets regulation</li>
        </ul>

        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mt-12 mb-4">Languages</h2>
        <p class="text-slate-700 dark:text-slate-300">
          Fluent in French (native), English, and Spanish; elementary proficiency in Italian and German
        </p>

        <div class="mt-12 p-6 bg-blue-50 dark:bg-slate-800 rounded-lg border border-blue-200 dark:border-slate-700">
          <p class="text-slate-700 dark:text-slate-300">
            Want to talk agentic AI — the platform or the strategy? <a href="https://www.linkedin.com/in/beaumois/" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">Connect with me on LinkedIn</a> or explore <a href="https://meetloyd.com" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">MeetLoyd</a>.
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
